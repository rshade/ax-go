# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
/bin/
/integration
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Transient artifacts written by the apidiff CI gate when run locally
/apidiff-comment.md
/apidiff.txt
# Stray binary from `go build ./internal/cmd/apidiff-verdict` (workflow uses `go run`)
/apidiff-verdict

# env file
.env
.env*

# Node tooling
node_modules/
dist/
build/
*.log

# Astro (docs site) content cache
docs/.astro/

# Editor/IDE
.idea/
.vscode/
.DS_Store
Thumbs.db
*.tmp
*.swp

# Dependency directories
vendor/
PR_MESSAGE.md
.claude/agent-memory/
